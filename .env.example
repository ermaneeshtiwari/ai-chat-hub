OPENAI_API_KEY=your_openai_api_key_here
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
OPENAI_MODELS=gpt-4.1-mini,gpt-4o-mini,gpt-4o

# Optional provider: Groq
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant
GROQ_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile

# Optional provider: OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_MODELS=openai/gpt-4o-mini,anthropic/claude-3.5-sonnet,google/gemini-2.0-flash-001

# Optional provider: Gemini
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-pro

PORT=3000
RATE_LIMIT_MAX=60
MAX_HISTORY_MESSAGES=12
# Optional: enable browser basic auth by setting both values.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
